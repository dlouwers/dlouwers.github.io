---
import '@dlouwers/stormlantern-tokens/css';
import '../styles/site.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dirk Louwers',
  description = 'Notes on software, systems, and finance tooling.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      // Pre-paint theme bootstrap. Sets [data-theme] before stylesheets load
      // so token CSS resolves to the right values without a flash.
      (() => {
        const stored = localStorage.getItem('sl-theme');
        if (stored === 'dark' || stored === 'light') {
          document.documentElement.setAttribute('data-theme', stored);
        }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/brand/lantern-mark.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/brand/lantern-mark-dark.svg" media="(prefers-color-scheme: dark)" />

    <link rel="alternate" type="application/rss+xml" title={title} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
  </head>
  <body>
    <!-- SVG duotone filter, hidden, available globally. Maps luminance to a
         brand-coloured palette (shadows → tinted-900, highlights → teal-300)
         for any <img> with class="duotone-teal". -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter id="sl-duotone-teal" color-interpolation-filters="sRGB">
          <feColorMatrix type="matrix" values="
            0.2126 0.7152 0.0722 0 0
            0.2126 0.7152 0.0722 0 0
            0.2126 0.7152 0.0722 0 0
            0      0      0      1 0"/>
          <feComponentTransfer>
            <feFuncR tableValues="0.0235 0.3922"/>
            <feFuncG tableValues="0.0941 0.6471"/>
            <feFuncB tableValues="0.1020 0.6510"/>
          </feComponentTransfer>
        </filter>
      </defs>
    </svg>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Registers all sl-* custom elements on the client.
      // Bundled by Astro/Vite; tree-shake by switching to per-component
      // imports later if any page becomes JS-weight-sensitive.
      import '@dlouwers/stormlantern-components';
    </script>
  </body>
</html>
