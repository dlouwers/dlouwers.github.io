---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <span>© {year} Dirk Louwers</span>
    <span>
      <a href="/rss.xml">RSS</a>
      <span class="sep">·</span>
      <a href="https://github.com/dlouwers/dlouwers.github.io">Source</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--sl-color-line);
    margin-top: var(--sl-space-12);
    color: var(--sl-color-muted);
    font-size: var(--sl-font-size-sm);
  }
  .footer-inner {
    width: 100%;
    max-width: 72ch;
    margin: 0 auto;
    padding: var(--sl-space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sl-space-4);
  }
  .footer-inner a { color: var(--sl-color-muted); }
  .footer-inner a:hover { color: var(--sl-color-body); }
  .sep { margin: 0 var(--sl-space-2); opacity: 0.6; }
</style>
