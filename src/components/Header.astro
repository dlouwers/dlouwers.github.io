---
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
};
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand-lockup" aria-label="Stormlantern home">
      <img class="light" src="/brand/lockup.svg" alt="Stormlantern" height="28" />
      <img class="dark" src="/brand/lockup-dark.svg" alt="Stormlantern" height="28" />
    </a>
    <nav>
      <a href="/" class:list={['nav-link', { active: isActive('/') }]}>Home</a>
      <a href="/tags/" class:list={['nav-link', { active: isActive('/tags/') }]}>Tags</a>
      <a href="/rss.xml" class="nav-link">RSS</a>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--sl-color-line);
    background: var(--sl-color-surface);
  }
  .header-inner {
    width: 100%;
    max-width: 72ch;
    margin: 0 auto;
    padding: var(--sl-space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sl-space-4);
  }
  .brand-lockup { display: inline-flex; align-items: center; }
  .brand-lockup img { height: 28px; width: auto; }
  .brand-lockup .light { display: block; }
  .brand-lockup .dark  { display: none; }
  :root[data-theme="dark"] .brand-lockup .light { display: none; }
  :root[data-theme="dark"] .brand-lockup .dark  { display: block; }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .brand-lockup .light { display: none; }
    :root:not([data-theme]) .brand-lockup .dark  { display: block; }
  }
  nav {
    display: flex;
    align-items: center;
    gap: var(--sl-space-4);
    font-size: var(--sl-font-size-sm);
  }
  .nav-link {
    color: var(--sl-color-body);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 120ms cubic-bezier(0.2, 0, 0.2, 1),
                border-color 120ms cubic-bezier(0.2, 0, 0.2, 1);
  }
  .nav-link:hover { color: var(--sl-color-ink); }
  .nav-link.active {
    color: var(--sl-color-ink);
    border-bottom-color: var(--sl-color-accent);
  }
</style>
