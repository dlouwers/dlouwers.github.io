---
// Comments via Giscus (GitHub Discussions backend, "Comments" category).
// Theme follow: the giscus iframe is on giscus.app, so its own
// `prefers-color-scheme` reflects the OS, not our site's [data-theme].
// We resolve the *effective* site theme in JS and postMessage it to the
// iframe — on its first handshake, on `sl-theme-change`, and on OS scheme
// flips while the site is in system mode.
// IDs come from giscus.app for dlouwers/dlouwers.github.io.

const REPO_ID = 'MDEwOlJlcG9zaXRvcnkyODg1NDY0Ng==';
const CATEGORY_ID = 'DIC_kwDOAbhJds4C8s4S';
const ENABLED = REPO_ID && CATEGORY_ID;
---
{ENABLED ? (
  <>
    <div id="giscus-container"></div>
    <script is:inline
      src="https://giscus.app/client.js"
      data-repo="dlouwers/dlouwers.github.io"
      data-repo-id={REPO_ID}
      data-category="Comments"
      data-category-id={CATEGORY_ID}
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="light"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
    <script>
      const darkQuery = window.matchMedia('(prefers-color-scheme: dark)');

      const effectiveTheme = (): 'light' | 'dark_dimmed' => {
        const attr = document.documentElement.getAttribute('data-theme');
        if (attr === 'light') return 'light';
        if (attr === 'dark') return 'dark_dimmed';
        return darkQuery.matches ? 'dark_dimmed' : 'light';
      };

      const send = (theme: string) => {
        const frame = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
        if (!frame) return;
        frame.contentWindow?.postMessage(
          { giscus: { setConfig: { theme } } },
          'https://giscus.app'
        );
      };

      // First handshake from the iframe → push the current effective theme.
      // The iframe sends its first message once it's ready to accept setConfig.
      let synced = false;
      window.addEventListener('message', (e) => {
        if (synced) return;
        if (e.origin !== 'https://giscus.app') return;
        if (!(e.data && (e.data as { giscus?: unknown }).giscus)) return;
        synced = true;
        send(effectiveTheme());
      });

      document.addEventListener('sl-theme-change', () => {
        send(effectiveTheme());
      });

      // When the site is in system mode (no [data-theme] attribute), follow
      // OS scheme flips live. If the user has explicitly toggled, ignore —
      // the site itself ignores OS in that case too.
      darkQuery.addEventListener('change', () => {
        if (document.documentElement.hasAttribute('data-theme')) return;
        send(effectiveTheme());
      });
    </script>
  </>
) : (
  <aside class="giscus-todo">
    Comments are not configured yet. See <code>src/components/Giscus.astro</code>
    for setup steps.
  </aside>
)}

<style>
  .giscus-todo {
    margin-top: var(--sl-space-8);
    padding: var(--sl-space-3) var(--sl-space-4);
    border: 1px dashed var(--sl-color-line);
    border-radius: var(--sl-radius-sm);
    color: var(--sl-color-muted);
    font-size: var(--sl-font-size-sm);
  }
</style>
