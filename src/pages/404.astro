---
import BaseLayout from '../layouts/BaseLayout.astro';

const lostSrc = '/img/404.jpg';
const lostAlt = 'A small rowboat adrift on a stormy sea — lost.';
---
<BaseLayout title="Not found — Dirk Louwers" description="That page does not exist.">
  <div class="container">
    <figure class="lost" aria-hidden="true">
      <img class="duotone-teal" src={lostSrc} alt={lostAlt} />
    </figure>
    <div class="wave-divider wave-divider--sm" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 12" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
        <path d="M0 6 Q 7.5 1 15 6 T 30 6 T 45 6 T 60 6 T 75 6 T 90 6 T 105 6 T 120 6"/>
      </svg>
    </div>
    <h1>404</h1>
    <p>That page does not exist (or has migrated). Try the <a href="/">home page</a>.</p>
  </div>
</BaseLayout>

<style>
  .container {
    text-align: center;
    padding-top: var(--sl-space-10);
    padding-bottom: var(--sl-space-16);
  }
  .lost {
    margin: 0 auto var(--sl-space-8);
    max-width: 720px;
    aspect-ratio: 3 / 2;
    border: 1px solid var(--sl-color-line);
    border-radius: var(--sl-radius-md);
    overflow: hidden;
    background: var(--sl-color-tinted-900);
  }
  .lost img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .wave-divider { margin: 0 auto var(--sl-space-6); }
  h1 {
    font-family: var(--sl-font-family-display);
    font-size: 6rem;
    font-weight: var(--sl-font-weight-heavy);
    color: var(--sl-color-ink);
    margin: 0;
    line-height: 1;
  }
  p { color: var(--sl-color-muted); margin-top: var(--sl-space-4); }
</style>
